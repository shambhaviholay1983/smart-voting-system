import mysql.connector

# 1. Database Credentials
host = "localhost"
user = "root"
password = "Holay@123"  # Enter your MySQL password here if you have one

try:
    # 2. Establish Connection to the Server
    db_server = mysql.connector.connect(
        host=host,
        user=user,
        password=password
    )

    # 3. Define the CURSOR (This fixes the NameError)
    cursor = db_server.cursor()

    # 4. Create and use the Database
    cursor.execute("CREATE DATABASE IF NOT EXISTS SmartVotingSystem")
    cursor.execute("USE SmartVotingSystem")
    print("Database 'SmartVotingSystem' connected.")

    # 5. List of Queries
    queries = [
        """
        CREATE TABLE IF NOT EXISTS Aadhaar_Master (
            aadhaar_id INT AUTO_INCREMENT PRIMARY KEY,
            aadhaar_number VARCHAR(12) NOT NULL UNIQUE,
            full_name VARCHAR(100),
            biometric_hash LONGTEXT
        )
        """,
        """
        CREATE TABLE IF NOT EXISTS EPIC_Master (
            voter_id INT AUTO_INCREMENT PRIMARY KEY,
            epic_id VARCHAR(10) NOT NULL UNIQUE,
            voter_status ENUM('Active', 'Expired') DEFAULT 'Active'
        )
        """,
        """
        CREATE TABLE IF NOT EXISTS Aadhaar_EPIC_Link (
            link_id INT AUTO_INCREMENT PRIMARY KEY,
            aadhaar_number VARCHAR(12) UNIQUE,
            epic_id VARCHAR(10) UNIQUE,
            FOREIGN KEY (aadhaar_number) REFERENCES Aadhaar_Master(aadhaar_number),
            FOREIGN KEY (epic_id) REFERENCES EPIC_Master(epic_id)
        )
        """
    ]

    # 6. Execute Queries
    for query in queries:
        cursor.execute(query)
        print("Table processed successfully.")

# 7. This 'except' block fixes the SyntaxError
except mysql.connector.Error as err:
    print(f"Error: {err}")

finally:
    # 8. Close connections
    if 'db_server' in locals() and db_server.is_connected():
        cursor.close()
        db_server.close()
        print("MySQL connection closed.")